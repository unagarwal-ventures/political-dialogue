{
  "name": "political-dialogue",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=shared && npm run build --workspace=client && npm run build --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
